# OCTOPUS — copy to .env or set in your shell (never commit real keys)

# Optional default model (user must still /login for API key)
# OCTOPUS_DEFAULT_MODEL=openrouter/free

# Provider API keys (any one or more)
# OPENROUTER_API_KEY=
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GEMINI_API_KEY=
# DEEPSEEK_API_KEY=

# Config directory override
# OCTOPUS_HOME=~/.octopus
